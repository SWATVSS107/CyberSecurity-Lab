import pandas as pd

df = pd.read_csv("malicious_phish.csv")
print(df.head())
# remove duplicates
df = df.drop_duplicates()

# check null values
df = df.dropna()

# convert labels if needed
df['type'] = df['type'].map({'benign':0, 'phishing':1, 'defacement':2, 'malware':3, 'ransomware':4})
import re

def extract_features(url):
    return [
        len(url),                     # length
        url.count('.'),               # number of dots
        url.count('/'),               # slashes
        url.count('-'),               # hyphen
        url.count('@'),               # @ symbol
        sum(c.isdigit() for c in url),# digits count
        1 if 'https' in url else 0    # https
    ]

features = df['url'].apply(lambda x: extract_features(x))
X = pd.DataFrame(features.tolist(), columns=[
    'length','dots','slashes','hyphen','at','digits','https'
])

y = df['type']
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier

X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)

model = RandomForestClassifier()
model.fit(X_train, y_train)
def predict_url(url):
    f = extract_features(url)
    return model.predict([f])

print(predict_url("http://free-money.xyz"))
